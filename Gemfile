source 'https://rubygems.org'

group :jekyll_plugins do
  gem 'jekyll'
  gem 'jekyll-feed'
  gem 'jekyll-sitemap'
  gem 'jekyll-redirect-from'
  gem 'jemoji'
  gem 'webrick', '~> 1.8'
end

gem 'github-pages'

# Windows 无系统 zoneinfo 目录时，Jekyll 需要 tzinfo-data（否则报 TZInfo::DataSourceNotFound）
gem 'tzinfo', '>= 1', '< 3'
gem 'tzinfo-data', platforms: [:windows, :jruby]
